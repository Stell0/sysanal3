#!/bin/bash
#
# sysanal3 - NethServer 8 System Analyzer
# Analyzes a NethServer 8 system and searches for known issues automatically.
#
# Usage: bash <(curl -sfL https://raw.githubusercontent.com/Stell0/sysanal3/main/sysanal3)
#

set -o pipefail

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

PROBLEMS=0
WARNINGS=0
declare -a PROBLEM_MSGS=()
declare -a WARNING_MSGS=()
declare -a LOCAL_IPS_ARRAY=()

problem() { echo -e "${RED}[PROBLEM]${NC} $*"; PROBLEM_MSGS+=("$*"); ((PROBLEMS++)); }
warning() { echo -e "${YELLOW}[WARNING]${NC} $*"; WARNING_MSGS+=("$*"); ((WARNINGS++)); }
info()    { echo -e "${CYAN}[INFO]${NC} $*"; }
ok()      { echo -e "${GREEN}[OK]${NC} $*"; }
header()  { echo ""; echo -e "${BOLD}=== $* ===${NC}"; }

LOCAL_IPS_DISPLAY="N/A"
PUBLIC_IP=""

get_listener_lines_by_port() {
    local port="$1"
    {
        ss -H -ltnp "( sport = :${port} )" 2>/dev/null
        ss -H -lunp "( sport = :${port} )" 2>/dev/null
    } | sed '/^$/d'
}

get_listener_processes_by_port() {
    local port="$1"
    local listeners
    listeners=$(get_listener_lines_by_port "$port")
    if [[ -z "$listeners" ]]; then
        return
    fi
    echo "$listeners" | grep -oE '"[^"]+"' | tr -d '"' | sort -u | xargs
}

check_port() {
    local desc="$1" port="$2"
    local listeners processes
    listeners=$(get_listener_lines_by_port "$port")
    if [[ -n "$listeners" ]]; then
        processes=$(get_listener_processes_by_port "$port")
        if [[ -n "$processes" ]]; then
            ok "${desc}: port ${port} is listening (processes: ${processes})"
        else
            ok "${desc}: port ${port} is listening"
        fi
    else
        problem "${desc}: port ${port} is NOT listening"
    fi
}

check_port_owner() {
    local desc="$1" port="$2" expected_regex="$3" expected_service="$4"
    local listeners processes
    listeners=$(get_listener_lines_by_port "$port")
    processes=$(get_listener_processes_by_port "$port")

    if [[ -z "$listeners" ]]; then
        problem "${desc}: port ${port} is NOT listening"
        return 1
    fi

    if [[ -n "$expected_regex" ]] && ! echo " ${processes} " | grep -qiE "$expected_regex"; then
        problem "${desc}: port ${port} is used by [${processes:-unknown}] instead of ${expected_service}"
        return 1
    fi

    ok "${desc}: port ${port} is listening (processes: ${processes:-unknown})"
    return 0
}

init_network_identity() {
    local raw_ips ip
    raw_ips=$(hostname -I 2>/dev/null | xargs || true)

    LOCAL_IPS_ARRAY=()
    if [[ -n "$raw_ips" ]]; then
        read -r -a LOCAL_IPS_ARRAY <<< "$raw_ips"
        LOCAL_IPS_DISPLAY="$raw_ips"
    fi

    PUBLIC_IP=""
    if ! command -v curl >/dev/null 2>&1; then
        return
    fi

    for ip_service in \
        "https://api64.ipify.org" \
        "https://ipv4.icanhazip.com" \
        "https://ifconfig.me/ip"
    do
        ip=$(curl -4 -fsS --max-time 5 "$ip_service" 2>/dev/null | tr -d '[:space:]' || true)
        if [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
            PUBLIC_IP="$ip"
            return
        fi
    done
}

is_local_ip() {
    local candidate="$1" ip
    [[ -z "$candidate" ]] && return 1
    for ip in "${LOCAL_IPS_ARRAY[@]}"; do
        [[ "$candidate" == "$ip" ]] && return 0
    done
    return 1
}

is_port_listening() {
    local port="$1"
    [[ -n "$(get_listener_lines_by_port "$port")" ]]
}

is_port_listening_by_process() {
    local port="$1" expected_regex="$2"
    local processes
    processes=$(get_listener_processes_by_port "$port")
    [[ -n "$processes" ]] && echo " ${processes} " | grep -qiE "$expected_regex"
}

probe_hairpin_udp_sip() {
    local public_ip="$1"
    local port="$2"
    local local_ip branch tag call_id payload response

    [[ "$public_ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || {
        echo "invalid public IP: $public_ip" >&2
        return 2
    }

    [[ "$port" =~ ^[0-9]+$ ]] && (( port >= 1 && port <= 65535 )) || {
        echo "invalid port: $port" >&2
        return 2
    }

    local_ip="$(ip route get "$public_ip" 2>/dev/null | awk '
        {
            for (i = 1; i <= NF; i++) {
                if ($i == "src") {
                    print $(i+1)
                    exit
                }
            }
        }'
    )"

    [[ -n "$local_ip" ]] || {
        echo "cannot determine local source IP for $public_ip" >&2
        return 2
    }

    branch="z9hG4bK-sysanal3-$$-$RANDOM"
    tag="sysanal3-$RANDOM"
    call_id="sysanal3-$RANDOM-$$@$local_ip"

    payload=$(
        printf 'OPTIONS sip:sysanal3@%s:%s SIP/2.0\r\n' "$public_ip" "$port"
        printf 'Via: SIP/2.0/UDP %s;rport;branch=%s\r\n' "$local_ip" "$branch"
        printf 'Max-Forwards: 70\r\n'
        printf 'From: <sip:sysanal3@%s>;tag=%s\r\n' "$local_ip" "$tag"
        printf 'To: <sip:sysanal3@%s:%s>\r\n' "$public_ip" "$port"
        printf 'Call-ID: %s\r\n' "$call_id"
        printf 'CSeq: 1 OPTIONS\r\n'
        printf 'Contact: <sip:sysanal3@%s>\r\n' "$local_ip"
        printf 'Content-Length: 0\r\n'
    )

    printf '%s\n' "$payload" > /dev/null

    exec 3<>"/dev/udp/$public_ip/$port" 2>/dev/null || return 3

    printf '%s' "$payload" >&3 || {
        exec 3>&-
        exec 3<&-
        return 1
    }

    # Read one UDP datagram, not a "line"
    if ! response="$(timeout 4 dd bs=65535 count=1 status=none <&3 2>/dev/null)"; then
        exec 3>&-
        exec 3<&-
        return 1
    fi
 
    exec 3>&-
    exec 3<&-
}


probe_hairpin_tcp_tls() {
    local public_ip="$1" port="$2"

    if ! command -v openssl >/dev/null 2>&1; then
        return 2
    fi

    timeout 6 openssl s_client -connect "${public_ip}:${port}" -brief </dev/null >/dev/null 2>&1
}

check_hairpin_nat_for_nethvoice() {
    local nv_mod="$1"
    local port processes
    local expected_regex='(^| )kamailio( |$)'

    if [[ -z "$PUBLIC_IP" ]]; then
        info "${nv_mod}: hairpin NAT checks skipped: public IP not available"
        return
    fi

    if is_local_ip "$PUBLIC_IP"; then
        info "${nv_mod}: hairpin NAT checks skipped: public IP matches a local machine address (${PUBLIC_IP})"
        return
    fi

    for port in 5060 5061 10001; do
        if [[ "$port" != "10001" ]] && ! is_port_listening "$port"; then
            info "${nv_mod}: hairpin NAT check skipped for port ${port}: port is not listening"
            continue
        fi

        if [[ "$port" != "10001" ]] && ! is_port_listening_by_process "$port" "$expected_regex"; then
            processes=$(get_listener_processes_by_port "$port")
            info "${nv_mod}: hairpin NAT check skipped for port ${port}: port is owned by [${processes:-unknown}] instead of kamailio"
            continue
        fi

        case "$port" in
            5060)
                if probe_hairpin_udp_sip "$PUBLIC_IP" "$port"; then
                    ok "${nv_mod}: hairpin NAT works for SIP/UDP port ${port} via ${PUBLIC_IP}"
                else
                    case $? in
                        2) info "${nv_mod}: hairpin NAT check skipped for SIP/UDP port ${port}: /dev/udp is not available" ;;
                        *) problem "${nv_mod}: hairpin NAT failed for SIP/UDP port ${port} via ${PUBLIC_IP}" ;;
                    esac
                fi
                ;;
            5061)
                if probe_hairpin_tcp_tls "$PUBLIC_IP" "$port"; then
                    ok "${nv_mod}: hairpin NAT works for SIP/TLS port ${port} via ${PUBLIC_IP}"
                else
                    case $? in
                        2) info "${nv_mod}: hairpin NAT check skipped for SIP/TLS port ${port}: openssl is not available" ;;
                        *) problem "${nv_mod}: hairpin NAT failed for SIP/TLS port ${port} via ${PUBLIC_IP}" ;;
                    esac
                fi
                ;;
            10001)
                if is_port_listening_by_process "$port" "$expected_regex"; then
                    warning "${nv_mod}: hairpin NAT check for UDP port ${port} is inconclusive: kamailio is listening on ${PUBLIC_IP}:${port}, but no deterministic reply-based probe is available"
                else
                    processes=$(get_listener_processes_by_port "$port")
                    warning "${nv_mod}: hairpin NAT check for UDP port ${port} is inconclusive: no kamailio listener was found locally (found: ${processes:-none}), and no deterministic reply-based probe is available"
                fi
                ;;
        esac
    done
}

get_env_numeric_var() {
    local env_file="$1" var_name="$2"
    grep -oP "^${var_name}=\K[0-9]+$" "$env_file" 2>/dev/null | head -1
}

# ---------------------------------------------------------------------------
# Configurable constants
# ---------------------------------------------------------------------------
RESTART_THRESHOLD=5            # Container restarts above this count flag a problem
DNS_SLOW_MS=2000               # DNS resolution slower than this (ms) flags a problem
QUEUE_RINGALL_MAX_QUEUES=3     # Warn if ringall strategy is used by more than this number of queues
QUEUE_RINGALL_MAX_AGENTS=5     # Warn if any ringall queue has more than this number of agents
INTERNET_OK=1                  # Set to 0 if connectivity precheck fails
IS_WORKER=0                    # Set to 1 when running via SSH on a worker node

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --worker) IS_WORKER=1; shift ;;
        *)        shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Pre-flight
# ---------------------------------------------------------------------------
if [[ $EUID -ne 0 ]]; then
    echo "This script must be run as root"
    exit 1
fi

echo -e "${BOLD}sysanal3 - NethServer 8 System Analyzer V3${NC}"
echo "========================================="
echo "Date: $(date)"

init_network_identity

# ---------------------------------------------------------------------------
# Internet connectivity precheck
# ---------------------------------------------------------------------------
header "Pre-check: Internet connectivity"

if ping -qc 1 -W 3 sos.nethesis.it &>/dev/null; then
    ok "Internet connectivity OK (sos.nethesis.it reachable)"
else
    warning "No internet connectivity (sos.nethesis.it unreachable) — GitHub version checks will be skipped"
    INTERNET_OK=0
fi

# ---------------------------------------------------------------------------
# General System Data
# ---------------------------------------------------------------------------
header "General System Data"

# IP addresses
info "IP addresses: ${LOCAL_IPS_DISPLAY}"
info "Public IP: ${PUBLIC_IP:-unavailable}"
if [[ -z "$PUBLIC_IP" ]]; then
    warning "Public IP could not be determined; hairpin NAT checks will be skipped"
fi

# DNS nameservers
_nameservers=$(grep -E '^nameserver' /etc/resolv.conf 2>/dev/null | awk '{print $2}' | xargs || true)
info "DNS nameservers: ${_nameservers:-N/A}"

# Hostname / FQDN
info "Hostname: $(hostname -f 2>/dev/null || hostname 2>/dev/null || echo 'N/A')"

# Open file descriptors
_filenr=$(cat /proc/sys/fs/file-nr 2>/dev/null || true)
if [[ -n "$_filenr" ]]; then
    _used=$(echo "$_filenr" | awk '{print $1}')
    _max=$(echo "$_filenr" | awk '{print $3}')
    info "Open file descriptors: ${_used} / ${_max}"
    if [[ "$_max" -gt 0 ]] && (( _used * 100 / _max >= 90 )); then
        problem "Open file descriptors at ${_used}/${_max} (>= 90%)"
    fi
fi

# Root filesystem usage
_rootfs=$(df -h / 2>/dev/null | awk 'NR==2{printf "%s used / %s total (%s full)", $3, $2, $5}')
info "Root filesystem: ${_rootfs:-N/A}"
_root_pct=$(df / 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
if [[ -n "$_root_pct" && "$_root_pct" -ge 90 ]]; then
    problem "Root filesystem usage at ${_root_pct}% (>= 90%)"
fi

# CPU load average
_cpu_cores=$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || true)
_load_avg_1=$(awk '{print $1}' /proc/loadavg 2>/dev/null || true)
if [[ -n "$_cpu_cores" && -n "$_load_avg_1" ]]; then
    info "CPU load average (1m): ${_load_avg_1} on ${_cpu_cores} core(s)"
    if awk -v load_avg="$_load_avg_1" -v cores="$_cpu_cores" 'BEGIN { exit !(load_avg > (2 * cores)) }'; then
        problem "CPU load average is ${_load_avg_1} on ${_cpu_cores} core(s) (> 2x core count)"
    elif awk -v load_avg="$_load_avg_1" -v cores="$_cpu_cores" 'BEGIN { exit !(load_avg > cores) }'; then
        warning "CPU load average is ${_load_avg_1} on ${_cpu_cores} core(s) (> core count)"
    fi
fi

# Uptime
info "Uptime: $(uptime -p 2>/dev/null || uptime | sed 's/.*up/up/' || echo 'N/A')"

# Timezone
_tz=$(timedatectl 2>/dev/null | grep -i 'time zone' | awk '{print $3, $4, $5}' || true)
info "Timezone: ${_tz:-N/A}"

# Cluster subscription system_id
_sub_id=$(redis-cli --raw hget cluster/subscription system_id 2>/dev/null || true)
if [[ -z "$_sub_id" ]]; then
    warning "Cluster subscription system_id is empty or missing"
else
    info "Subscription system_id: ${_sub_id}"
fi

# Cluster UUID
_cluster_uuid=$(redis-cli --raw get cluster/uuid 2>/dev/null || true)
info "Cluster UUID: ${_cluster_uuid:-N/A}"

# ---------------------------------------------------------------------------
# 1. Check for sngrep running > 1 day
# ---------------------------------------------------------------------------
header "Check: sngrep long-running instances"

sngrep_pids=$(pgrep -x sngrep 2>/dev/null || true)
if [[ -n "$sngrep_pids" ]]; then
    while read -r pid; do
        elapsed=$(ps -o etimes= -p "$pid" 2>/dev/null | tr -d ' ')
        if [[ -n "$elapsed" && "$elapsed" -gt 86400 ]]; then
            elapsed_days=$((elapsed / 86400))
            problem "sngrep (PID $pid) running for ${elapsed_days} day(s)"
        else
            info "sngrep (PID $pid) running for less than 1 day"
        fi
    done <<< "$sngrep_pids"
else
    ok "No sngrep instances found"
fi

# ---------------------------------------------------------------------------
# 2. List all modules on this node
# ---------------------------------------------------------------------------
header "Check: List all modules on this node"

# NODE_ID is stored in /var/lib/nethserver/node/state/environment
NODE_ID=$(grep -oP '^NODE_ID=\K.*' /var/lib/nethserver/node/state/environment 2>/dev/null || true)
if [[ -z "$NODE_ID" ]]; then
    # Fallback: extract from AGENT_ID in agent.env (e.g. "node/1" -> "1")
    NODE_ID=$(grep -oP '^AGENT_ID=node/\K\d+' /var/lib/nethserver/node/state/agent.env 2>/dev/null || true)
fi
if [[ -z "$NODE_ID" ]]; then
    problem "Cannot determine node ID (checked /var/lib/nethserver/node/state/environment and agent.env)"
    NODE_ID="1"
fi

# Leader-node detection and multi-node info
LEADER_VPN_IP=$(redis-cli --raw hget node/1/vpn endpoint 2>/dev/null | cut -d: -f1 || true)
TOTAL_NODES=$(redis-cli --raw KEYS 'node/*/vpn' 2>/dev/null | wc -l || echo 1)
IS_LEADER=0
if [[ "$NODE_ID" == "1" ]]; then
    IS_LEADER=1
fi
info "Node ${NODE_ID} of ${TOTAL_NODES} total node(s) (leader: $(if [[ $IS_LEADER -eq 1 ]]; then echo 'yes'; else echo 'no'; fi))"

# Fetch installed modules from Redis (works on both leader and worker nodes).
# Redis on workers runs as a replica — all cluster/* and module/* keys are
# replicated from the leader, so read operations work everywhere.
# Output format per line: id|source|version|module
MODULES_ON_NODE=""
_module_node_raw=$(redis-cli --raw HGETALL cluster/module_node 2>/dev/null || true)
if [[ -n "$_module_node_raw" ]]; then
    # HGETALL returns alternating key/value lines: module_id\nnode_id\n...
    _prev_key=""
    while IFS= read -r _line; do
        if [[ -z "$_prev_key" ]]; then
            _prev_key="$_line"
        else
            _mod_id="$_prev_key"
            _mod_node="$_line"
            _prev_key=""
            # Only process modules on this node
            [[ "$_mod_node" != "$NODE_ID" ]] && continue
            # Get IMAGE_URL from module environment (</dev/null prevents redis-cli from consuming loop stdin)
            _image_url=$(redis-cli --raw HGET "module/${_mod_id}/environment" IMAGE_URL </dev/null 2>/dev/null || true)
            [[ -z "$_image_url" ]] && continue
            # Parse: source = URL without tag, version = tag, module = last path component of source
            _source="${_image_url%:*}"
            _version="${_image_url##*:}"
            _module="${_source##*/}"
            MODULES_ON_NODE+="${_mod_id}|${_source}|${_version}|${_module}"$'\n'
        fi
    done <<< "$_module_node_raw"
    # Sort and strip trailing newline
    MODULES_ON_NODE=$(echo "$MODULES_ON_NODE" | sort | sed '/^$/d')
else
    warning "Cannot retrieve installed modules from Redis"
fi

# Plain list of module IDs for later checks
MODULES=$(echo "$MODULES_ON_NODE" | cut -d'|' -f1 | grep -v '^$' || true)

if [[ -z "$MODULES" ]]; then
    warning "No modules found on node ${NODE_ID}"
else
    info "Modules on node ${NODE_ID}:"
    while IFS='|' read -r mod_id mod_source mod_version mod_name; do
        echo "  - ${mod_id} (${mod_name}) version ${mod_version}"
    done <<< "$MODULES_ON_NODE"
fi

# ---------------------------------------------------------------------------
# 3. Module version vs latest GitHub release
# ---------------------------------------------------------------------------
header "Check: Module version vs latest GitHub release"

if [[ $INTERNET_OK -eq 0 ]]; then
    warning "Skipping GitHub version checks (no internet connectivity)"
else

check_module_version() {
    local mod_id="$1"
    local mod_source="$2"
    local mod_version="$3"
    local mod_name="$4"

    if [[ -z "$mod_source" || -z "$mod_version" ]]; then
        warning "${mod_id}: missing source or version info"
        return
    fi

    # Derive GitHub repo from source image URL
    # e.g. ghcr.io/nethserver/traefik -> nethserver/ns8-traefik
    # e.g. ghcr.io/nethesis/nethvoice -> nethesis/ns8-nethvoice
    local image_path="${mod_source#*/}"    # drop registry host (ghcr.io/)
    local org="${image_path%%/*}"          # e.g. "nethserver" or "nethesis"
    local github_repo="${org}/ns8-${mod_name}"

    local latest_tag
    latest_tag=$(curl -sf --max-time 10 \
        "https://api.github.com/repos/${github_repo}/releases/latest" \
        | grep -oP '"tag_name"\s*:\s*"\K[^"]+' || true)

    if [[ -z "$latest_tag" ]]; then
        info "${mod_id}: cannot fetch latest release for ${github_repo} (installed: ${mod_version})"
        return
    fi

    if [[ "$mod_version" != "$latest_tag" ]]; then
        warning "${mod_id}: installed ${mod_version}, latest is ${latest_tag} (repo: ${github_repo})"
    else
        ok "${mod_id}: up to date (${mod_version})"
    fi
}

if [[ -n "$MODULES_ON_NODE" ]]; then
    while IFS='|' read -r mod_id mod_source mod_version mod_name; do
        check_module_version "$mod_id" "$mod_source" "$mod_version" "$mod_name"
    done <<< "$MODULES_ON_NODE"
else
    info "No modules to check"
fi

fi  # end INTERNET_OK check

# ---------------------------------------------------------------------------
# 3b. Per-module container health overview
# ---------------------------------------------------------------------------
header "Check: Container health per module"

if [[ -n "$MODULES" ]]; then
    while read -r mod; do
        container_info=$(runagent -m "$mod" podman ps -a --format '{{.Names}} [Status:{{.Status}}] [Restarts:{{.Restarts}}]' 2>/dev/null || true)
        if [[ -z "$container_info" ]]; then
            continue
        fi
        info "Containers for ${mod}:"
        while read -r cline; do
            echo "  ${cline}"
            # Flag unhealthy states
            if echo "$cline" | grep -qiE '\[Status:(Created|Exited|Paused)'; then
                warning "${mod}: container not running — ${cline%% \[*}"
            fi
            # Flag high restart counts
            _restarts=$(echo "$cline" | grep -oP '\[Restarts:\K[0-9]+' || echo 0)
            if [[ "$_restarts" -gt "$RESTART_THRESHOLD" ]]; then
                problem "${mod}: container ${cline%% \[*} has ${_restarts} restarts (threshold: ${RESTART_THRESHOLD})"
            fi
        done <<< "$container_info"

        # Show TRAEFIK_HOST if present
        _traefik_host=$(cat "/home/${mod}/.config/state/environment" 2>/dev/null | grep -oP '^TRAEFIK_HOST=\K.*' || true)
        if [[ -n "$_traefik_host" ]]; then
            info "${mod}: TRAEFIK_HOST=${_traefik_host}"
        fi
    done <<< "$MODULES"
else
    info "No modules to check"
fi

# ---------------------------------------------------------------------------
# 4. Failed systemd services
# ---------------------------------------------------------------------------
header "Check: Failed systemd services"

# System-wide
failed_system=$(systemctl --failed --no-legend --no-pager 2>/dev/null || true)
if [[ -n "$failed_system" ]]; then
    problem "Failed system services:"
    while read -r line; do
        echo "  ${line}"
    done <<< "$failed_system"
else
    ok "No failed system services"
fi

# Per-module (user services — failed and dead)
if [[ -n "$MODULES" ]]; then
    while read -r mod; do
        failed_user=$(runagent -m "$mod" systemctl --user --failed --no-legend --no-pager 2>/dev/null || true)
        if [[ -n "$failed_user" ]]; then
            problem "Failed services in module ${mod}:"
            while read -r line; do
                echo "  ${line}"
            done <<< "$failed_user"
        fi

        # Also check for dead services (not failed but not running)
        dead_services=$(runagent -m "$mod" systemctl --user list-units --type=service --no-legend --no-pager 2>/dev/null \
            | awk '$3 == "inactive" || $4 == "dead" {print $1, $3, $4}' || true)
        if [[ -n "$dead_services" ]]; then
            warning "Dead/inactive services in module ${mod}:"
            while read -r line; do
                echo "  ${line}"
            done <<< "$dead_services"
        fi
    done <<< "$MODULES"
fi

# ---------------------------------------------------------------------------
# 5. NethVoice-specific checks
# ---------------------------------------------------------------------------
header "Check: NethVoice modules"

# Match only "nethvoice" modules, not "nethvoice-proxy" or other nethvoice-* variants
nethvoice_modules=$(echo "$MODULES_ON_NODE" | awk -F'|' '$4 == "nethvoice" {print $1}' || true)
if [[ -n "$nethvoice_modules" ]]; then
    while read -r nv_mod; do
        info "Checking NethVoice module: ${nv_mod}"

        # --- DNS resolution inside freepbx container ---
        dns_start=$(date +%s%N)
        dns_out=$(runagent -m "$nv_mod" podman exec freepbx getent hosts ibm.com 2>&1 || true)
        dns_end=$(date +%s%N)
        dns_ms=$(( (dns_end - dns_start) / 1000000 ))

        if [[ -z "$dns_out" || "$dns_ms" -gt $DNS_SLOW_MS ]]; then
            problem "${nv_mod}: DNS resolution failed or too slow (${dns_ms}ms, getent hosts ibm.com)"
            info "${nv_mod}: /etc/resolv.conf inside container freepbx:"
            runagent -m "$nv_mod" podman exec freepbx cat /etc/resolv.conf 2>/dev/null | while read -r line; do
                echo "  ${line}"
            done
        else
            ok "${nv_mod}: DNS OK (ibm.com resolved in ${dns_ms}ms)"
        fi

        # --- mysqlcheck ---
        # Run mysqlcheck inside the mariadb container; root password is in $MARIADB_ROOT_PASSWORD
        mysql_out=$(runagent -m "$nv_mod" podman exec mariadb \
            sh -c 'mysqlcheck -uroot -p${MARIADB_ROOT_PASSWORD} -A' 2>&1 || true)

        if echo "$mysql_out" | grep -qiE 'error|corrupt|crashed'; then
            problem "${nv_mod}: mysqlcheck reported errors:"
            echo "$mysql_out" | grep -iE 'error|corrupt|crashed' | while read -r line; do
                echo "  ${line}"
            done
        elif [[ -z "$mysql_out" ]]; then
            warning "${nv_mod}: mysqlcheck returned no output (mariadb container may not exist)"
        else
            ok "${nv_mod}: mysqlcheck OK"
        fi

        # --- Asterisk PJSIP contacts ---
        pjsip_out=$(runagent -m "$nv_mod" podman exec freepbx asterisk -rx 'pjsip show contacts' 2>/dev/null || true)
        if [[ -n "$pjsip_out" ]]; then
            pjsip_count=$(echo "$pjsip_out" | grep -c '/sip:' || true)
            info "${nv_mod}: PJSIP registered contacts: ${pjsip_count}"
            if [[ "$pjsip_count" -eq 0 ]]; then
                # Check if asterisk is actually running
                ast_running=$(runagent -m "$nv_mod" podman exec freepbx pgrep asterisk 2>/dev/null || true)
                if [[ -n "$ast_running" ]]; then
                    warning "${nv_mod}: Asterisk running but zero PJSIP contacts registered"
                fi
            fi
        else
            info "${nv_mod}: could not retrieve PJSIP contacts (Asterisk may not be running)"
        fi

        # --- Asterisk AstDB call forward (CF) ---
        cf_out=$(runagent -m "$nv_mod" podman exec freepbx asterisk -rx 'database show CF' 2>/dev/null || true)
        if [[ -n "$cf_out" ]]; then
            # Parse AstDB output lines like:
            #   /CF/200                                       : 210
            # and keep a unique extension|destination mapping for later checks.
            cf_mappings=$(echo "$cf_out" | awk '
                /^[[:space:]]*\/CF\// {
                    line = $0
                    sub(/^[[:space:]]*\/CF\//, "", line)
                    split(line, parts, /[[:space:]]*:[[:space:]]*/)
                    ext = parts[1]
                    dest = parts[2]
                    sub(/[[:space:]].*$/, "", ext)
                    sub(/^[[:space:]]+/, "", dest)
                    sub(/[[:space:]]+$/, "", dest)
                    if (ext != "") {
                        print ext "|" dest
                    }
                }
            ' | sort -u)

            if [[ -n "$cf_mappings" ]]; then
                declare -A cf_targets=()
                declare -A reported_cf_cycles=()

                while IFS='|' read -r cf_ext cf_dest; do
                    [[ -z "$cf_ext" ]] && continue
                    # Keep only a numeric extension target so we can walk CF chains.
                    # If the destination is external or non-numeric, the extension still
                    # gets a warning but it is not considered for circular-chain checks.
                    cf_target=""
                    if [[ "$cf_dest" =~ ^[0-9]+$ ]]; then
                        cf_target="$cf_dest"
                    elif [[ "$cf_dest" =~ (^|[^0-9])([0-9]{2,})([^0-9]|$) ]]; then
                        cf_target="${BASH_REMATCH[2]}"
                    fi

                    cf_targets["$cf_ext"]="$cf_target"
                    warning "${nv_mod}: Extension ${cf_ext} has call forward enabled"
                done <<< "$cf_mappings"

                # Follow each extension CF chain until it ends or loops back to a
                # previously visited extension. A repeated node means a circular CF.
                for start_ext in "${!cf_targets[@]}"; do
                    declare -A visited_cf=()
                    cf_path=()
                    current_ext="$start_ext"

                    while [[ -n "$current_ext" && -n "${cf_targets[$current_ext]+x}" ]]; do
                        if [[ -n "${visited_cf[$current_ext]+x}" ]]; then
                            cycle_start_index=${visited_cf[$current_ext]}
                            cycle_exts=( "${cf_path[@]:$cycle_start_index}" )
                            cycle_desc=""
                            for cycle_ext in "${cycle_exts[@]}"; do
                                if [[ -n "$cycle_desc" ]]; then
                                    cycle_desc+=" -> "
                                fi
                                cycle_desc+="$cycle_ext"
                            done
                            cycle_desc+=" -> ${current_ext}"

                            for cycle_ext in "${cycle_exts[@]}"; do
                                if [[ -z "${reported_cf_cycles[$cycle_ext]+x}" ]]; then
                                    problem "${nv_mod}: Extension ${cycle_ext} has circular call forward configuration (${cycle_desc})"
                                    reported_cf_cycles["$cycle_ext"]=1
                                fi
                            done
                            break
                        fi

                        visited_cf["$current_ext"]=${#cf_path[@]}
                        cf_path+=("$current_ext")
                        next_ext="${cf_targets[$current_ext]}"
                        if [[ -z "$next_ext" ]]; then
                            break
                        fi
                        current_ext="$next_ext"
                    done
                done
            else
                ok "${nv_mod}: no extensions with call forward enabled (AstDB CF)"
            fi
        else
            info "${nv_mod}: could not retrieve AstDB CF entries"
        fi

        # --- Asterisk queue ring strategy ---
        queue_out=$(runagent -m "$nv_mod" podman exec freepbx asterisk -rx 'queue show' 2>/dev/null || true)
        if [[ -n "$queue_out" ]]; then
            # Parse `queue show` output queue-by-queue and count members only for
            # queues whose strategy is explicitly set to `ringall`.
            ringall_queue_agents=$(echo "$queue_out" | awk -v sq="'" '
                BEGIN {
                    queue = ""
                    is_ringall = 0
                    in_members = 0
                    agents = 0
                }

                function flush_queue() {
                    if (is_ringall && queue != "") {
                        print queue "|" agents
                    }
                }

                /^[^[:space:]].* has .* strategy/ {
                    flush_queue()
                    queue = ""
                    is_ringall = 0
                    in_members = 0
                    agents = 0

                    if (match($0, /^(.+) has .* in /, m)) {
                        queue = m[1]
                    }
                    if (index($0, " in " sq "ringall" sq " strategy") > 0) {
                        is_ringall = 1
                    }
                    next
                }

                is_ringall && /^[[:space:]]+Members:[[:space:]]*$/ {
                    in_members = 1
                    next
                }

                is_ringall && /^[[:space:]]+Callers:[[:space:]]*$/ {
                    in_members = 0
                    next
                }

                is_ringall && in_members {
                    if ($0 ~ /^[[:space:]]+[^[:space:]]+/ && $0 !~ /^[[:space:]]+No Members/) {
                        agents++
                    }
                    next
                }

                END {
                    flush_queue()
                }
            ')

            ringall_queue_count=$(echo "$ringall_queue_agents" | sed '/^$/d' | wc -l)
            max_ringall_agents=0
            max_ringall_queue=""
            ringall_over_limit=""

            if [[ -n "$ringall_queue_agents" ]]; then
                # Evaluate both warning conditions:
                # 1. too many queues using ringall
                # 2. any ringall queue with too many agents
                while IFS='|' read -r queue_name queue_agents; do
                    [[ -z "$queue_name" ]] && continue
                    [[ -z "$queue_agents" || ! "$queue_agents" =~ ^[0-9]+$ ]] && queue_agents=0

                    if (( queue_agents > max_ringall_agents )); then
                        max_ringall_agents=$queue_agents
                        max_ringall_queue=$queue_name
                    fi

                    if (( queue_agents > QUEUE_RINGALL_MAX_AGENTS )); then
                        ringall_over_limit+="${queue_name}(${queue_agents}) "
                    fi
                done <<< "$ringall_queue_agents"
            fi

            if (( ringall_queue_count > QUEUE_RINGALL_MAX_QUEUES )) || [[ -n "$ringall_over_limit" ]]; then
                warning "${nv_mod}: Asterisk ringall strategy may overload endpoints (ringall queues: ${ringall_queue_count}, threshold: ${QUEUE_RINGALL_MAX_QUEUES}; queues with >${QUEUE_RINGALL_MAX_AGENTS} agents: ${ringall_over_limit:-none})"
            elif (( ringall_queue_count > 0 )); then
                info "${nv_mod}: ringall queues: ${ringall_queue_count} (max agents in a ringall queue: ${max_ringall_agents}${max_ringall_queue:+ in ${max_ringall_queue}})"
            else
                ok "${nv_mod}: no queues using ringall strategy"
            fi
        else
            info "${nv_mod}: could not retrieve queue strategy data (Asterisk queue show unavailable)"
        fi

        # --- Port variables and service ownership checks ---
        nv_env_file="/home/${nv_mod}/.config/state/environment"
        if [[ ! -f "$nv_env_file" ]]; then
            warning "${nv_mod}: cannot read environment file (${nv_env_file}) for port checks"
            continue
        fi

        nv_port_vars=$(grep -E '^[A-Z0-9_]*PORT[A-Z0-9_]*=[0-9]+$' "$nv_env_file" 2>/dev/null || true)
        if [[ -z "$nv_port_vars" ]]; then
            warning "${nv_mod}: no numeric *PORT* variables found in environment"
            continue
        fi

        sftp_service_enabled=0
        if [[ -n "$(echo "$nv_port_vars" | grep '^ASTERISK_RECORDING_SFTP_PORT=' || true)" ]]; then
            sftp_state=$(runagent -m "$nv_mod" systemctl --user is-enabled sftp.service 2>/dev/null | head -1 || true)
            if [[ "$sftp_state" == "enabled" ]]; then
                sftp_service_enabled=1
            fi
        fi

        satellite_service_running=0
        satellite_mqtt_service_running=0
        satellite_pgsql_service_running=0

        if [[ -n "$(echo "$nv_port_vars" | grep -E '^(SATELLITE_HTTP_PORT|SATELLITE_RTP_PORT)=' || true)" ]]; then
            satellite_state=$(runagent -m "$nv_mod" systemctl --user is-active satellite.service 2>/dev/null | head -1 || true)
            if [[ "$satellite_state" == "active" ]]; then
                satellite_service_running=1
            fi
        fi

        if [[ -n "$(echo "$nv_port_vars" | grep '^SATELLITE_MQTT_PORT=' || true)" ]]; then
            satellite_mqtt_state=$(runagent -m "$nv_mod" systemctl --user is-active satellite-mqtt.service 2>/dev/null | head -1 || true)
            if [[ "$satellite_mqtt_state" == "active" ]]; then
                satellite_mqtt_service_running=1
            fi
        fi

        if [[ -n "$(echo "$nv_port_vars" | grep '^SATELLITE_PGSQL_PORT=' || true)" ]]; then
            satellite_pgsql_state=$(runagent -m "$nv_mod" systemctl --user is-active satellite-pgsql.service 2>/dev/null | head -1 || true)
            if [[ "$satellite_pgsql_state" == "active" ]]; then
                satellite_pgsql_service_running=1
            fi
        fi

        info "${nv_mod}: PORT variables and listening processes"
        while IFS='=' read -r nv_var nv_port; do
            [[ -z "$nv_var" || -z "$nv_port" ]] && continue

            if [[ "$nv_var" == "STUNPORT" ]]; then
                continue
            fi

            if [[ "$nv_var" == "ASTERISK_RECORDING_SFTP_PORT" && "$sftp_service_enabled" -ne 1 ]]; then
                info "${nv_mod}: ${nv_var}=${nv_port} skipped (sftp.service is not enabled)"
                continue
            fi

            if [[ "$nv_var" == "SATELLITE_HTTP_PORT" && "$satellite_service_running" -ne 1 ]]; then
                info "${nv_mod}: ${nv_var}=${nv_port} skipped (satellite.service is not running)"
                continue
            fi

            if [[ "$nv_var" == "SATELLITE_RTP_PORT" && "$satellite_service_running" -ne 1 ]]; then
                info "${nv_mod}: ${nv_var}=${nv_port} skipped (satellite.service is not running)"
                continue
            fi

            if [[ "$nv_var" == "SATELLITE_MQTT_PORT" && "$satellite_mqtt_service_running" -ne 1 ]]; then
                info "${nv_mod}: ${nv_var}=${nv_port} skipped (satellite-mqtt.service is not running)"
                continue
            fi

            if [[ "$nv_var" == "SATELLITE_PGSQL_PORT" && "$satellite_pgsql_service_running" -ne 1 ]]; then
                info "${nv_mod}: ${nv_var}=${nv_port} skipped (satellite-pgsql.service is not running)"
                continue
            fi

            nv_processes=$(get_listener_processes_by_port "$nv_port")

            if [[ -n "$nv_processes" ]]; then
                info "${nv_mod}: ${nv_var}=${nv_port} -> ${nv_processes}"
            else
                problem "${nv_mod}: ${nv_var}=${nv_port} is not used by any listening process"
                continue
            fi

            case "$nv_var" in
                ASTERISK_SIP_PORT|ASTERISK_SIPS_PORT|ASTERISK_IAX_PORT|ASTERISK_WS_PORT|ASTERISK_WSS_PORT|ASTMANAGERPORT)
                    if ! echo " ${nv_processes} " | grep -qiE '(^| )asterisk( |$)'; then
                        problem "${nv_mod}: ${nv_var}=${nv_port} is not used by asterisk (found: ${nv_processes})"
                    fi
                    ;;
                PROXY_PORT)
                    if ! echo " ${nv_processes} " | grep -qiE '(^| )kamailio( |$)'; then
                        problem "${nv_mod}: ${nv_var}=${nv_port} is not used by kamailio (found: ${nv_processes})"
                    fi
                    ;;
            esac
        done <<< "$nv_port_vars"

        # Compare configured Asterisk ports from the module environment with the
        # actual ports currently owned by the asterisk process on the host.
        expected_asterisk_ports=$(echo "$nv_port_vars" | awk -F= '/^(ASTERISK_SIP_PORT|ASTERISK_SIPS_PORT|ASTERISK_IAX_PORT|ASTERISK_WS_PORT|ASTERISK_WSS_PORT|ASTMANAGERPORT)=/{print $2}' | sort -n -u | xargs)
        asterisk_listeners=$(ss -H -ltnup 2>/dev/null | grep 'users:(("asterisk"' || true)
        actual_asterisk_ports=$(echo "$asterisk_listeners" | awk '{print $5}' | awk -F: '{print $NF}' | grep -E '^[0-9]+$' | sort -n -u | xargs)

        if [[ -n "$expected_asterisk_ports" ]]; then
            for expected_port in $expected_asterisk_ports; do
                if ! echo " ${actual_asterisk_ports} " | grep -q " ${expected_port} "; then
                    problem "${nv_mod}: asterisk is not listening on expected port ${expected_port}"
                fi
            done
        fi

        for forbidden_port in 5060 5061; do
            if echo " ${actual_asterisk_ports} " | grep -q " ${forbidden_port} "; then
                problem "${nv_mod}: asterisk must not listen on forbidden port ${forbidden_port}"
            fi
        done

        expected_sip_port=$(get_env_numeric_var "$nv_env_file" "ASTERISK_SIP_PORT")
        if [[ -n "$expected_sip_port" ]]; then
            pjsip_transports=$(runagent -m "$nv_mod" podman exec freepbx asterisk -rx 'pjsip show transports' 2>/dev/null || true)
            if [[ -n "$pjsip_transports" ]]; then
                if echo "$pjsip_transports" | grep -qE ":[[:space:]]*${expected_sip_port}([[:space:]]|$)|:${expected_sip_port}/"; then
                    ok "${nv_mod}: Asterisk PJSIP transport uses ASTERISK_SIP_PORT=${expected_sip_port}"
                else
                    problem "${nv_mod}: Asterisk PJSIP transport does not use ASTERISK_SIP_PORT=${expected_sip_port}"
                fi
            fi
        fi
    done <<< "$nethvoice_modules"
else
    info "No NethVoice modules found"
fi

# ---------------------------------------------------------------------------
# 6. Listening Ports / Sockets
# ---------------------------------------------------------------------------
header "Check: Listening ports for installed services"

# Traefik (always expected on NS8)
traefik_modules=$(echo "$MODULES" | grep -i "^traefik" || true)
if [[ -n "$traefik_modules" ]]; then
    check_port "Traefik HTTP" 80
    check_port "Traefik HTTPS" 443
fi

# NethVoice SIP ports
if [[ -n "$nethvoice_modules" ]]; then
    while read -r nv_mod; do
        nv_env_file="/home/${nv_mod}/.config/state/environment"
        if [[ ! -f "$nv_env_file" ]]; then
            warning "${nv_mod}: cannot read environment file (${nv_env_file}) for NethVoice port checks"
            continue
        fi

        proxy_port=$(get_env_numeric_var "$nv_env_file" "PROXY_PORT")
        asterisk_sip_port=$(get_env_numeric_var "$nv_env_file" "ASTERISK_SIP_PORT")
        asterisk_sips_port=$(get_env_numeric_var "$nv_env_file" "ASTERISK_SIPS_PORT")

        if [[ -n "$proxy_port" ]]; then
            check_port_owner "${nv_mod} Kamailio SIP" "$proxy_port" '(^| )kamailio( |$)' "kamailio"
        else
            warning "${nv_mod}: PROXY_PORT is not set"
        fi

        if [[ -n "$asterisk_sip_port" ]]; then
            check_port_owner "${nv_mod} Asterisk SIP" "$asterisk_sip_port" '(^| )asterisk( |$)' "asterisk"
        else
            warning "${nv_mod}: ASTERISK_SIP_PORT is not set"
        fi

        if [[ -n "$asterisk_sips_port" ]]; then
            check_port_owner "${nv_mod} Asterisk SIPS" "$asterisk_sips_port" '(^| )asterisk( |$)' "asterisk"
        else
            warning "${nv_mod}: ASTERISK_SIPS_PORT is not set"
        fi

        check_hairpin_nat_for_nethvoice "$nv_mod"
    done <<< "$nethvoice_modules"
fi

# Samba / NethService AD
samba_modules=$(echo "$MODULES" | grep -i "^samba" || true)
if [[ -n "$samba_modules" ]]; then
    check_port "Samba LDAP" 389
    check_port "Samba LDAPS" 636
fi

# Mail
mail_modules=$(echo "$MODULES" | grep -i "^mail" || true)
if [[ -n "$mail_modules" ]]; then
    check_port "Mail SMTP" 25
    check_port "Mail IMAP" 143
    check_port "Mail IMAPS" 993
fi

if [[ -z "$traefik_modules" && -z "$nethvoice_modules" && -z "$samba_modules" && -z "$mail_modules" ]]; then
    info "No well-known services to check ports for"
fi

# ---------------------------------------------------------------------------
# 7. CrowdSec – check if local IPs are blocked
# ---------------------------------------------------------------------------
header "Check: CrowdSec IP blocking"

crowdsec_modules=$(echo "$MODULES" | grep -i "^crowdsec" || true)
if [[ -n "$crowdsec_modules" ]]; then
    cs_mod=$(echo "$crowdsec_modules" | head -1)
    warning "CrowdSec module found: ${cs_mod} (may cause connectivity issues)"

    # Find the CrowdSec container
    cs_container=$(runagent -m "$cs_mod" podman ps --format '{{.Names}}' 2>/dev/null \
        | grep -i crowdsec | head -1 || true)

    if [[ -z "$cs_container" ]]; then
        warning "CrowdSec container not found in module ${cs_mod}"
    else
        # Collect all local IPs (skip loopback)
        local_ips=$(ip -o addr show 2>/dev/null \
            | awk '{print $4}' | cut -d/ -f1 \
            | grep -v '^127\.' | grep -v '^::1$' | sort -u)

        blocked_found=0
        if [[ -n "$local_ips" ]]; then
            while read -r ip; do
                result=$(runagent -m "$cs_mod" podman exec "$cs_container" \
                    cscli decisions list -i "$ip" -o raw 2>/dev/null | tail -n +2 || true)
                if [[ -n "$result" ]]; then
                    problem "CrowdSec: local IP ${ip} is BLOCKED"
                    echo "  ${result}"
                    blocked_found=1
                fi
            done <<< "$local_ips"

            if [[ "$blocked_found" -eq 0 ]]; then
                ok "CrowdSec: no local IPs are blocked (checked $(echo "$local_ips" | wc -l) addresses)"
            fi
        else
            warning "Could not determine local IP addresses"
        fi
    fi
else
    info "No CrowdSec module found, skipping"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo -e "${BOLD}=========================================${NC}"
echo -e "${BOLD}Summary (Node ${NODE_ID})${NC}"
echo -e "  Problems: ${RED}${PROBLEMS}${NC}"
echo -e "  Warnings: ${YELLOW}${WARNINGS}${NC}"
echo -e "${BOLD}=========================================${NC}"

if [[ ${#PROBLEM_MSGS[@]} -gt 0 ]]; then
    echo ""
    echo -e "${RED}${BOLD}Problems:${NC}"
    for msg in "${PROBLEM_MSGS[@]}"; do
        echo -e "  ${RED}[PROBLEM]${NC} ${msg}"
    done
fi

if [[ ${#WARNING_MSGS[@]} -gt 0 ]]; then
    echo ""
    echo -e "${YELLOW}${BOLD}Warnings:${NC}"
    for msg in "${WARNING_MSGS[@]}"; do
        echo -e "  ${YELLOW}[WARNING]${NC} ${msg}"
    done
fi

if [[ $PROBLEMS -gt 0 ]]; then
    exit 1
fi

exit 0
